// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER") // USER, ADMIN
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Global Site Settings for dynamic branding
model SiteSettings {
  id              String @id @default("global")
  siteName        String @default("SPORTSURF")
  logoUrl         String?
  primaryColor    String @default("#6366f1")
  secondaryColor  String @default("#f59e0b")
  fontHeading     String @default("Inter")
  fontBody        String @default("Inter")
  contactEmail    String?
  contactPhone    String?
  address         String?
  showCategoryBar Boolean @default(true)
  showTicker      Boolean @default(true)
  statsJson       String? @default("[]") // Array of { value, label }
  certsJson       String? @default("[]") // Array of { title, imageUrl }
  ctaTitle        String? @default("Ready to build your dream stadium?")
  ctaSubtitle     String? @default("Contact us to get a complete guide & quote.")
  ctaButton       String? @default("GET A QUOTE")
  ctaLink         String? @default("/contact")
}

model TickerUpdate {
  id    String @id @default(cuid())
  text  String
  order Int    @default(0)
}

model Category {
  id            String   @id @default(cuid())
  label         String   @unique
  description   String?
  icon          String?  @default("default")
  iconSvg       String?
  navbarIconUrl String?
  href          String?
  order         Int      @default(0)
  imageUrl      String?
}

model HomepageGridItem {
  id          String   @id @default(cuid())
  label       String   @unique
  description String?
  imageUrl    String?
  href        String?
  order       Int      @default(0)
}

// Navigation Management
model NavigationItem {
  id        String @id @default(cuid())
  label     String
  href      String
  order     Int    @default(0)
  parentId  String?
  parent    NavigationItem? @relation("NavHierarchy", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavHierarchy")
}

// Hero Sections
model HeroSection {
  id          String @id @default(cuid())
  page        String @unique // e.g., "home", "about", "contact"
  title       String
  subtitle    String?
  imageUrl    String?
  ctaText     String?
  ctaLink     String?
  textColor   String @default("#ffffff")
  overlayOpacity Float @default(0.4)
}

// Products
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  shortSpec   String?
  description String
  isNew       Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  heightClass String   @default("h-[400px]")
  imageUrl    String?
  specs       String?  // Stringified JSON Array of {label, value}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Projects
model Project {
  id          String   @id @default(cuid())
  name        String
  city        String
  state       String
  surface     String
  area        String
  year        String
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Testimonials
model Testimonial {
  id          String @id @default(cuid())
  name        String
  institution String
  quote       String
  avatar      String?
  order       Int    @default(0)
}

// Contact Requests & Quotes
model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  city      String?
  surface   String?  // For quick quotes
  message   String
  status    String   @default("pending") // pending, read, resolved
  createdAt DateTime @default(now())
}

// Verification OTP
model Otp {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
}
